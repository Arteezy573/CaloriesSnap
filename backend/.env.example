# Backend configuration. Copy to .env and fill in real values.
# JWT signing secret (change in production)
JWT_SECRET=dev-secret-change-in-production
# Invite code required to register
INVITE_CODE=caloriessnap2026
# Resend email provider API key. If UNSET, the backend logs verification/reset
# codes to the server log instead of sending email (handy for local dev).
RESEND_API_KEY=
# Verified sender address used for outgoing email.
EMAIL_FROM=CaloriesSnap <noreply@caloriessnap.app>
