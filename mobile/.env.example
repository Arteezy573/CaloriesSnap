# Base URL of the CaloriesSnap backend the app talks to.
# Production (Azure): https://caloriessnap.azurewebsites.net
# Local backend from an emulator/device: use your machine's LAN IP, e.g. http://192.168.1.50:8000
# (plain localhost only works for the web build, not a phone/emulator)
EXPO_PUBLIC_API_URL=https://caloriessnap.azurewebsites.net
